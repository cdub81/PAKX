{
  "expo": {
    "name": "PAKX Alliance App",
    "slug": "pakx-alliance-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "scheme": "pakxallianceapp",
    "userInterfaceStyle": "light",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true
          }
        }
      ]
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.cdub81.pakxallianceapp",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cdub81.pakxallianceapp",
      "versionCode": 1
    },
    "extra": {
      "eas": {
        "projectId": "75491678-b571-4dcb-b86b-3817cc3f5951"
      }
    }
  }
}
